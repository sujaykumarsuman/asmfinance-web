# Build-time PUBLIC_* vars. Astro inlines these at build; they are NOT secrets.
# Copy to .env.local for local dev. CI sets these in .github/workflows/deploy.yml.

# Lead API base (the form POSTs to ${PUBLIC_API_BASE}/v1/leads). See docs/adr/003.
PUBLIC_API_BASE=https://api.asmfinance.tech

# Booking embed URL (Calendly or Zcal). Leave blank to hide the calendar column
# and fall back to the WhatsApp / "Send a message" path.
PUBLIC_CALENDLY_URL=

# Note: WhatsApp links are built from the phone number in src/data/site.json
# (contact.phoneDisplay) — there is no WhatsApp env var.

# Plausible Analytics domain (e.g. asmfinance.in). Leave blank to omit the
# analytics script entirely. Plausible only — no GA4 / FB Pixel (see ADR-001).
PUBLIC_PLAUSIBLE_DOMAIN=
