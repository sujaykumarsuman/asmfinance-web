---
import { Icon } from 'astro-icon/components';
// Small pill for credentials / trust signals (docs/03-design-system.md §TrustChip).
interface Props {
  icon?: string; // iconify name, e.g. "lucide:badge-check"
  class?: string;
}
const { icon, class: className = '' } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center gap-1.5 rounded-full border border-border px-3 py-1 text-small text-slate',
    className,
  ]}
>
  {icon && <Icon name={icon} class="h-4 w-4 text-emerald" aria-hidden="true" />}
  <slot />
</span>
