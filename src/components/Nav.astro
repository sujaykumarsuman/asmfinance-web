---
import { Icon } from 'astro-icon/components';
import Wordmark from './Wordmark.astro';
import Button from './Button.astro';
import { NAV_LINKS, ANCHORS } from '../lib/site';
// Sticky top nav. Mobile = wordmark + theme toggle + booking CTA; desktop (md+)
// adds the section links. Section links are also in the footer.
// The theme toggle is wired by the inline script in BaseLayout (data-theme-toggle).
---

<header
  class="sticky top-0 z-50 border-b border-border/80 bg-cream/90 backdrop-blur supports-[backdrop-filter]:bg-cream/75 dark:bg-night/90 dark:supports-[backdrop-filter]:bg-night/75"
>
  <div class="mx-auto flex h-16 w-full max-w-content items-center justify-between px-6 md:px-12 lg:px-20">
    <Wordmark href="/" />
    <div class="flex items-center gap-2 sm:gap-4">
      <nav aria-label="Primary" class="hidden md:flex md:items-center md:gap-8">
        {
          NAV_LINKS.map((l) => (
            <a
              href={l.href}
              class="text-small font-medium text-ink-soft transition-colors hover:text-forest dark:hover:text-sage"
            >
              {l.label}
            </a>
          ))
        }
      </nav>
      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle dark mode"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-ink-soft transition-colors hover:bg-ivory hover:text-forest dark:hover:text-sage"
      >
        <Icon name="lucide:moon" class="h-5 w-5 dark:hidden" aria-hidden="true" />
        <Icon name="lucide:sun" class="hidden h-5 w-5 dark:block" aria-hidden="true" />
      </button>
      <Button variant="primary" href={`#${ANCHORS.contact}`} size="sm">Request a call</Button>
    </div>
  </div>
</header>
