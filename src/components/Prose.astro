---
// Lightweight prose wrapper for long-form pages (privacy, terms, nri).
// Styles descendant elements with design tokens — no typography plugin needed.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    'max-w-prose text-body leading-relaxed text-ink-soft',
    '[&_:first-child]:mt-0',
    '[&_h1]:font-serif [&_h1]:text-h1 [&_h1]:text-forest',
    '[&_h2]:mt-10 [&_h2]:font-serif [&_h2]:text-h3 [&_h2]:text-forest',
    '[&_h3]:mt-6 [&_h3]:text-h4 [&_h3]:text-ink',
    '[&_p]:mt-4',
    '[&_ul]:mt-4 [&_ul]:list-disc [&_ul]:space-y-1.5 [&_ul]:pl-6',
    '[&_ol]:mt-4 [&_ol]:list-decimal [&_ol]:space-y-1.5 [&_ol]:pl-6',
    '[&_li]:pl-1',
    '[&_a]:font-medium [&_a]:text-emerald [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-forest',
    '[&_strong]:font-semibold [&_strong]:text-ink',
    className,
  ]}
>
  <slot />
</div>
