---
import { Icon } from 'astro-icon/components';
import SectionContainer from '../SectionContainer.astro';
import Eyebrow from '../Eyebrow.astro';
import { ANCHORS } from '../../lib/site';

// §5 NRI / GIFT City wedge — dark forest band, cream text, gold rules.
const geos = [
  { flag: 'circle-flags:ae', label: 'GCC' },
  { flag: 'circle-flags:us', label: 'US & Canada' },
  { flag: 'circle-flags:gb', label: 'UK & EU' },
  { flag: 'circle-flags:sg', label: 'Singapore & SEA' },
];
---

<SectionContainer id={ANCHORS.nri} bg="forest" class="scroll-mt-20">
  <div class="max-w-3xl">
    <Eyebrow tone="cream">FOR THE DIASPORA</Eyebrow>
    <h2 class="mt-3 text-h2 text-cream">Built for Indians abroad — finally.</h2>
    <span class="mt-6 block h-px w-10 bg-gold" aria-hidden="true"></span>

    <div class="mt-6 space-y-4 text-lead text-cream/90">
      <p>
        Most onshore Indian mutual funds don't accept US or Canada NRIs. GIFT City — India's
        International Financial Services Centre, USD-denominated and tax-efficient — does.
      </p>
      <p>
        We help families across the GCC, North America, the UK, EU and Singapore invest in India
        without the usual paperwork burden. One Indian touchpoint that handles investments,
        repatriation, taxes and succession.
      </p>
    </div>

    <ul class="mt-8 flex flex-wrap gap-2.5">
      {
        geos.map((g) => (
          <li class="inline-flex items-center gap-2 rounded-full border border-cream/25 px-3 py-1.5 text-small text-cream">
            <Icon name={g.flag} class="h-4 w-4" aria-hidden="true" />
            <span>{g.label}</span>
          </li>
        ))
      }
    </ul>

    <a
      href="/nri"
      class="mt-8 inline-flex items-center justify-center gap-2 rounded-md bg-cream px-5 py-3 font-medium text-forest transition-colors duration-150 ease-out hover:bg-gold-soft"
    >
      Read the NRI guide
      <Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
    </a>
  </div>
</SectionContainer>
