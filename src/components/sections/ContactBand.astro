---
import { Icon } from 'astro-icon/components';
import SectionContainer from '../SectionContainer.astro';
import Eyebrow from '../Eyebrow.astro';
import ContactForm from '../../islands/ContactForm';
import { SITE, ENV, ANCHORS, whatsappLink } from '../../lib/site';

// §3 Contact band — PRIORITY POSITION. Two equal columns on desktop, stacked on mobile.
// Left: lead form (React island, hydrates on scroll). Right: calendar embed + WhatsApp.
const wa = whatsappLink('Hi ASM Investments, I would like to talk.');
const hasCalendar = Boolean(ENV.calendlyUrl);
---

<SectionContainer id={ANCHORS.contact} bg="paper" class="scroll-mt-20">
  <div class="max-w-2xl">
    <Eyebrow>TALK TO US</Eyebrow>
    <h2 class="mt-3 text-h2 text-forest dark:text-sage">Start with a conversation, not a sales pitch.</h2>
    <p class="mt-4 text-lead text-slate">
      A free 30-minute online call to understand your situation. In-person meetings in Mathura,
      Delhi-NCR and Lucknow are possible by appointment — please mention your city.
    </p>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">
    <!-- Left: lead form (React island — hydrates only when scrolled into view) -->
    <div>
      <ContactForm
        client:visible
        apiBase={ENV.apiBase}
        email={SITE.email}
        whatsappHref={wa}
        privacyHref="/privacy"
      />
      <noscript>
        <div class="rounded-lg border border-border bg-cream p-6 text-body text-slate dark:bg-night">
          This form sends securely with JavaScript enabled. You can also email us directly at{' '}
          <a class="font-medium text-emerald underline underline-offset-2" href={`mailto:${SITE.email}`}>
            {SITE.email}
          </a>{wa ? ' or message us on WhatsApp.' : '.'}
        </div>
      </noscript>
    </div>

    <!-- Right: calendar embed -->
    <div>
      <h3 class="text-h4 text-ink">Or pick a time directly</h3>
      <div class="mt-4">
        {
          hasCalendar ? (
            <iframe
              src={ENV.calendlyUrl}
              title="Book a 30-minute call with ASM Investments"
              loading="lazy"
              class="h-[640px] w-full rounded-lg border border-border bg-cream dark:bg-night"
            />
          ) : (
            <div class="flex h-full flex-col items-start justify-center gap-3 rounded-lg border border-border bg-cream p-6 dark:bg-night">
              <Icon name="lucide:calendar-days" class="h-7 w-7 text-emerald" aria-hidden="true" />
              <p class="text-body text-slate">
                Online booking opens here. For now, use the form on the left — we reply within one
                business day.
              </p>
            </div>
          )
        }
      </div>

      <!-- WhatsApp quiet line -->
      <p class="mt-4 text-small text-slate">
        Prefer WhatsApp? {
          wa ? (
            <a href={wa} rel="noopener" class="inline-flex items-center gap-1 font-medium text-emerald underline underline-offset-2 hover:text-forest dark:hover:text-cream">
              <Icon name="lucide:message-circle" class="h-4 w-4" aria-hidden="true" />
              Tap to chat → {SITE.phoneDisplay}
            </a>
          ) : (
            <span>Tap to chat → {SITE.phoneDisplay}</span>
          )
        }
      </p>
    </div>
  </div>
</SectionContainer>
