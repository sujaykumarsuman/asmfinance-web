---
import { Icon } from 'astro-icon/components';
import SectionContainer from '../SectionContainer.astro';
import Eyebrow from '../Eyebrow.astro';
import ContactForm from '../../islands/ContactForm';
import { SITE, ENV, ANCHORS, whatsappLink } from '../../lib/site';

// §3 Contact band — PRIORITY POSITION. Two columns on desktop, stacked on mobile.
// Left: callback-request form (React island, hydrates on scroll).
// Right: direct ways to reach us (WhatsApp, phone, email, office, hours).
const wa = whatsappLink('Hi ASM Investments, I would like to talk.');
---

<SectionContainer id={ANCHORS.contact} bg="paper" class="scroll-mt-20">
  <div class="max-w-2xl">
    <Eyebrow>TALK TO US</Eyebrow>
    <h2 class="mt-3 text-h2 text-forest dark:text-sage">Start with a conversation, not a sales pitch.</h2>
    <p class="mt-4 text-lead text-slate">
      A free 30-minute call to understand your situation — no pressure, no jargon. Leave your
      details and the times that suit you, and we'll call you back, usually within one business day.
    </p>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">
    <!-- Left: callback-request form (React island — hydrates only when scrolled into view) -->
    <div>
      <ContactForm
        client:visible
        apiBase={ENV.apiBase}
        email={SITE.email}
        whatsappHref={wa}
        privacyHref="/privacy"
      />
      <noscript>
        <div class="rounded-lg border border-border bg-cream p-6 text-body text-slate dark:bg-night">
          This form sends securely with JavaScript enabled. You can also email us directly at{' '}
          <a class="font-medium text-emerald underline underline-offset-2" href={`mailto:${SITE.email}`}>
            {SITE.email}
          </a>{wa ? ' or message us on WhatsApp.' : '.'}
        </div>
      </noscript>
    </div>

    <!-- Right: direct ways to reach us -->
    <div>
      <h3 class="text-h4 text-ink">Prefer to reach us directly?</h3>

      {
        wa && (
          <a
            href={wa}
            rel="noopener"
            class="mt-4 flex items-center gap-3 rounded-lg border border-border bg-cream p-4 transition-colors hover:border-emerald dark:bg-night"
          >
            <Icon name="lucide:message-circle" class="h-6 w-6 shrink-0 text-emerald" aria-hidden="true" />
            <span>
              <span class="block font-medium text-ink">Chat on WhatsApp</span>
              <span class="block text-small text-slate">Tap to chat → {SITE.phoneDisplay}</span>
            </span>
          </a>
        )
      }

      <ul class="mt-6 space-y-4 text-body text-slate">
        <li class="flex items-center gap-3">
          <Icon name="lucide:phone" class="h-5 w-5 shrink-0 text-emerald" aria-hidden="true" />
          <span>{SITE.phoneDisplay}</span>
        </li>
        <li class="flex items-center gap-3">
          <Icon name="lucide:mail" class="h-5 w-5 shrink-0 text-emerald" aria-hidden="true" />
          <a
            href={`mailto:${SITE.email}`}
            class="underline-offset-2 hover:text-forest hover:underline dark:hover:text-cream"
          >
            {SITE.email}
          </a>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="lucide:map-pin" class="mt-0.5 h-5 w-5 shrink-0 text-emerald" aria-hidden="true" />
          <span>{SITE.office}</span>
        </li>
        <li class="flex items-center gap-3">
          <Icon name="lucide:clock" class="h-5 w-5 shrink-0 text-emerald" aria-hidden="true" />
          <span>{SITE.officeHours}</span>
        </li>
      </ul>

      <p class="mt-6 text-small text-muted">
        Online slot-booking isn't available yet — we prefer to call you and find a time that works.
      </p>
    </div>
  </div>
</SectionContainer>
