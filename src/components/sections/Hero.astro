---
import SectionContainer from '../SectionContainer.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';
import TrustChip from '../TrustChip.astro';
import { CTA, ANCHORS } from '../../lib/site';

// §1 Hero (docs/02-content-spec.md). Copy verbatim.
const trust = [
  'AMFI ARN-103139',
  'NISM V-A Certified',
  'Mirae Asset Sharekhan partner',
  'IRDAI POSP',
  'GIFT City partner network',
];
---

<SectionContainer bg="cream" spacing="none" class="pt-16 md:pt-20 lg:pt-24">
  <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
    <!-- Copy -->
    <div>
      <Eyebrow>AMFI-REGISTERED · MATHURA · EST. 2007</Eyebrow>
      <h1 class="mt-3 text-display text-forest text-balance">
        Wealth advisory for Indian families, wherever they live.
      </h1>
      <p class="mt-6 max-w-xl text-lead text-slate text-pretty">
        Investments, protection, taxes and legacy — handled by people who pick up the phone, backed
        by institutional-grade products from across India and GIFT City.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <Button variant="primary" href={`#${ANCHORS.contact}`}>{CTA.primary}</Button>
        <Button variant="secondary" href={`#${ANCHORS.contact}`}>{CTA.secondary}</Button>
      </div>
    </div>

    <!-- Supporting visual: founders cut-out, blended large into the cream (no frame/bg).
         The bottom mask fades the torso crop softly into the page.
         loading="lazy" => loads on desktop (in viewport) but skipped on mobile (display:none). -->
    <div class="hidden lg:block">
      <picture>
        <source
          type="image/webp"
          srcset="/founders/founders-transparent-800.webp 800w, /founders/founders-transparent-1600.webp 1600w"
          sizes="(min-width: 1024px) 46vw, 0px"
        />
        <img
          src="/founders/founders-transparent-800.png"
          srcset="/founders/founders-transparent-800.png 800w, /founders/founders-transparent-1600.png 1600w"
          sizes="(min-width: 1024px) 46vw, 0px"
          width="1600"
          height="1056"
          loading="lazy"
          decoding="async"
          alt="Anjali Suman and Arvind Kumar Suman, founders of ASM Investments"
          class="ml-auto w-full max-w-2xl select-none [mask-image:linear-gradient(to_bottom,black_76%,transparent_99%)] [-webkit-mask-image:linear-gradient(to_bottom,black_76%,transparent_99%)]"
        />
      </picture>
    </div>
  </div>

  <!-- Trust strip -->
  <div class="mt-12 border-t border-border pt-6 lg:mt-16">
    <ul class="flex flex-wrap gap-2.5">
      {trust.map((t) => (
        <li><TrustChip>{t}</TrustChip></li>
      ))}
    </ul>
  </div>
</SectionContainer>
