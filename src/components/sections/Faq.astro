---
import { Icon } from 'astro-icon/components';
import SectionContainer from '../SectionContainer.astro';
import Eyebrow from '../Eyebrow.astro';
import { ANCHORS } from '../../lib/site';

// §8 FAQ — native <details>/<summary> accordion (zero JS). Copy verbatim.
// Answers are trusted static strings; the only markup is the /nri link in Q3.
const faqs: { q: string; a: string }[] = [
  {
    q: 'Are you fee-based or commission-based?',
    a: `Both, depending on the tier. Core and Premium clients pay nothing — we earn a trail commission from the mutual funds we recommend. Wealth and NRI clients can opt for AUA-based advisory fees under our SEBI Registered Investment Adviser registration (in progress). We will never charge an advisory fee and a commission on the same product to the same client — that is regulated against.`,
  },
  {
    q: "I'm an NRI in the US — can I invest in Indian mutual funds?",
    a: `Most onshore Indian AMCs restrict US and Canada NRIs because of FATCA reporting. We use GIFT City Portfolio Management Services instead — securities are held in your own name, which avoids the PFIC tax trap most pooled funds create for US taxpayers. We pair this with a referral to a US-licensed CPA so your US tax position stays clean.`,
  },
  {
    q: 'What is GIFT City?',
    a: `GIFT City is India's International Financial Services Centre, located near Gandhinagar. Although it sits in India physically, it is treated as a foreign jurisdiction under FEMA. USD-denominated, tax-efficient, and accessible to NRIs from any geography. See our <a href="/nri" class="font-medium text-emerald underline underline-offset-2 hover:text-forest">NRI guide</a> for a longer explanation.`,
  },
  {
    q: 'Do you handle insurance?',
    a: `Yes — life, health, and general insurance. We are an IRDAI Point-of-Sale Person today and are upgrading to a Corporate Agent registration to offer products from up to nine insurers across categories.`,
  },
  {
    q: 'How quickly can I start?',
    a: `Resident Indians can be onboarded with their first investment in 48-72 hours after KYC. NRIs typically take 7-10 working days because of the document set required, plus IFSC banking unit account opening if going via GIFT City.`,
  },
  {
    q: 'How do I know my advisor will be around for the long run?',
    a: `ASM Investments is a two-generation practice. Arvind anchors current relationships, and the next generation is already involved in operations and tech. Every client meeting from the Wealth tier upward is co-signed by both, so continuity is baked in.`,
  },
  {
    q: 'What is the minimum to work with you?',
    a: `None for Core (SIP starting from ₹500/month). For Premium, we suggest at least ₹25 lakh investable to make a written plan worthwhile. Wealth begins at ₹2 crore. NRI Premium begins at the equivalent of about ₹50 lakh investable.`,
  },
  {
    q: 'Where can we meet in person?',
    a: `Mathura is home. We meet clients in Delhi-NCR, Lucknow and Agra periodically by appointment. For other cities and for NRIs, all calls are online over Zoom or WhatsApp.`,
  },
];
---

<SectionContainer id={ANCHORS.faq} bg="cream" class="scroll-mt-20">
  <div class="mx-auto max-w-3xl">
    <div class="max-w-2xl">
      <Eyebrow>COMMON QUESTIONS</Eyebrow>
      <h2 class="mt-3 text-h2 text-forest">Things people ask us before they sign on.</h2>
    </div>

    <div class="mt-8 border-t border-border">
      {
        faqs.map((item) => (
          <details class="group border-b border-border">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-h4 text-ink [&::-webkit-details-marker]:hidden">
              <span>{item.q}</span>
              <Icon
                name="lucide:chevron-down"
                class="h-5 w-5 shrink-0 text-emerald transition-transform duration-200 group-open:rotate-180"
                aria-hidden="true"
              />
            </summary>
            <div class="pb-5 pr-0 text-body text-slate sm:pr-8" set:html={item.a} />
          </details>
        ))
      }
    </div>
  </div>
</SectionContainer>
