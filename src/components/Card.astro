---
// Card surface: paper bg, hairline border, soft shadow, optional gold top accent
// and hover lift (docs/03-design-system.md §Card, §Motion).
interface Props {
  as?: 'div' | 'article' | 'li';
  hover?: boolean;
  accent?: boolean;
  class?: string;
}
const { as = 'div', hover = false, accent = true, class: className = '' } = Astro.props;
const Tag = as;
---

<Tag
  class:list={[
    'rounded-lg border border-border bg-paper p-6 shadow-card md:p-8',
    hover && 'transition duration-200 ease-out hover:-translate-y-0.5 hover:shadow-pop',
    className,
  ]}
>
  {accent && <span class="mb-4 block h-0.5 w-6 rounded-full bg-gold" aria-hidden="true"></span>}
  <slot />
</Tag>
