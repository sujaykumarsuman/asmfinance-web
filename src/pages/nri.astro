---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Prose from '../components/Prose.astro';
import { whatsappLink } from '../lib/site';

// NRI deep-dive. Concise per prompt; facts drawn from the spec's own NRI copy (FAQ, NRI band/tier).
// TODO(human): expand the long-form GIFT City explainer as a separate blog post and link it here.
const geos = [
  { flag: 'circle-flags:ae', label: 'GCC' },
  { flag: 'circle-flags:us', label: 'US & Canada' },
  { flag: 'circle-flags:gb', label: 'UK & EU' },
  { flag: 'circle-flags:sg', label: 'Singapore & SEA' },
];
const handles = [
  'NRE / NRO / FCNR account setup help',
  'GIFT City funds, PMS, USD ULIPs',
  'Repatriation and Form 15CA / 15CB via CA partner',
  'Cross-border tax pack (US clients paired with a US CPA)',
  'Will / succession basics across jurisdictions',
  'Service in your time zone',
];
const wa = whatsappLink('Hi ASM Investments, I am an NRI and would like to talk.');
---

<BaseLayout
  title="NRI & GIFT City Investing"
  description="How ASM Investments helps non-resident Indians invest in India — GIFT City funds and PMS, NRE/NRO/FCNR setup, repatriation, and cross-border tax, with one Indian touchpoint."
>
  <!-- Intro -->
  <SectionContainer bg="cream" spacing="tight" class="pt-16 md:pt-20">
    <div class="max-w-3xl">
      <Eyebrow>NRI &amp; GIFT CITY</Eyebrow>
      <h1 class="mt-3 text-h1 text-forest dark:text-sage">Invest in India from anywhere — cleanly.</h1>
      <p class="mt-6 text-lead text-slate">
        One Indian touchpoint that handles investments, repatriation, taxes and succession for
        families across the GCC, North America, the UK, EU and Singapore — without the usual
        paperwork burden.
      </p>
      <ul class="mt-8 flex flex-wrap gap-2.5">
        {
          geos.map((g) => (
            <li class="inline-flex items-center gap-2 rounded-full border border-border px-3 py-1.5 text-small text-slate">
              <Icon name={g.flag} class="h-4 w-4" aria-hidden="true" />
              <span>{g.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </SectionContainer>

  <!-- Why onshore funds fall short -->
  <SectionContainer bg="ivory">
    <Prose>
      <h2>Why most onshore Indian funds don't work for US &amp; Canada NRIs</h2>
      <p>
        Most onshore Indian AMCs restrict US and Canada NRIs because of FATCA reporting. Even where
        they don't, pooled Indian mutual funds can create the PFIC tax trap for US taxpayers —
        punitive tax treatment and heavy annual filing.
      </p>
      <p>
        We use GIFT City Portfolio Management Services instead. Securities are held in your own name,
        which avoids the PFIC problem, and we pair this with a referral to a US-licensed CPA so your
        US tax position stays clean.
      </p>

      <h2>What GIFT City is</h2>
      <p>
        GIFT City is India's International Financial Services Centre, located near Gandhinagar.
        Although it sits in India physically, it is treated as a foreign jurisdiction under FEMA.
        It is USD-denominated, tax-efficient, and accessible to NRIs from any geography — which makes
        it the cleanest way for many families abroad to invest into India.
      </p>
      <p class="text-small text-muted">
        A fuller GIFT City explainer is on the way as a separate guide. In the meantime, the summary
        above covers what matters for most families.
      </p>
    </Prose>
  </SectionContainer>

  <!-- What we handle -->
  <SectionContainer bg="cream">
    <div class="max-w-3xl">
      <h2 class="text-h2 text-forest dark:text-sage">What we handle for you</h2>
      <ul class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
        {
          handles.map((h) => (
            <li class="flex items-start gap-2 text-body text-ink-soft">
              <Icon name="lucide:check" class="mt-1 h-4 w-4 shrink-0 text-emerald" aria-hidden="true" />
              <span>{h}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </SectionContainer>

  <!-- CTA -->
  <SectionContainer bg="forest" spacing="tight">
    <div class="max-w-2xl">
      <h2 class="text-h2 text-cream">Talk to us about NRI services.</h2>
      <p class="mt-4 text-lead text-cream/90">
        A free 30-minute call in your time zone to map out the cleanest way to invest into India.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="/#contact"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-cream px-5 py-3 font-medium text-forest transition-colors duration-150 ease-out hover:bg-gold-soft"
        >
          Start a conversation
          <Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
        </a>
        {
          wa && (
            <a
              href={wa}
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-md border border-cream/40 px-5 py-3 font-medium text-cream transition-colors duration-150 ease-out hover:bg-cream/10"
            >
              <Icon name="lucide:message-circle" class="h-4 w-4" aria-hidden="true" />
              WhatsApp us
            </a>
          )
        }
      </div>
    </div>
  </SectionContainer>
</BaseLayout>
